}

func (f *Frontend) GetChannel(id int) (chan notificationChannel, bool) {
	channelsLock.Lock()
	defer channelsLock.Unlock()

	if channels == nil {
		return nil, false
	}

	ch, exists := channels[id]
	if exists {
		delete(channels, id)
	}
	return ch, exists
}

func (f *Frontend) cleanupChannel(id int) {
	channelsLock.Lock()
	defer channelsLock.Unlock()

	if channels == nil {
		return
	}

	if ch, exists := channels[id]; exists {
		delete(channels, id)
		close(ch)
	}
}
